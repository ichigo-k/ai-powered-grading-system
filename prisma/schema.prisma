generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  LECTURER
  STUDENT
}

model User {
  id           Int      @id @default(autoincrement())
  userId       String   @unique
  passwordHash String
  role         Role
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}
