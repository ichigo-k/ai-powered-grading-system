generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  LECTURER
  STUDENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum AssessmentType {
  EXAM
  QUIZ
  ASSIGNMENT
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SectionType {
  OBJECTIVE
  SUBJECTIVE
}

enum AnswerType {
  FILL_IN
  PDF_UPLOAD
  CODE
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  TIMED_OUT
}

enum GradingStatus {
  NOT_GRADED
  GRADING
  GRADED
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  passwordHash String
  role         Role
  name         String?
  status       UserStatus @default(ACTIVE)
  dateJoined   DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  studentProfile  StudentProfile?
  lecturerProfile LecturerProfile?
  adminProfile    AdminProfile?

  attempts AssessmentAttempt[]

  @@map("users")
}

model StudentProfile {
  id      Int    @id
  user    User   @relation(fields: [id], references: [id])
  program String
  classId Int?
  class   Class? @relation(fields: [classId], references: [id])

  @@map("student_profiles")
}

model LecturerProfile {
  id         Int    @id
  user       User   @relation(fields: [id], references: [id])
  department String
  title      String
  courses    Course[] @relation("LecturerCourses")

  assessments   Assessment[]
  questionBanks QuestionBank[]

  @@map("lecturer_profiles")
}

model AdminProfile {
  id   Int  @id
  user User @relation(fields: [id], references: [id])

  @@map("admin_profiles")
}

model Class {
  id          Int      @id @default(autoincrement())
  name        String   // e.g., "BIT Group B"
  level       Int      // e.g., 100
  isGraduated Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students StudentProfile[]
  courses  Course[]         @relation("ClassCourses")
  assessmentClasses AssessmentClass[]

  @@unique([name, level])
  @@map("classes")
}

model Course {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  title       String
  credits     Int      @default(3)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  classes   Class[]           @relation("ClassCourses")
  lecturers LecturerProfile[] @relation("LecturerCourses")

  assessments   Assessment[]
  questionBanks QuestionBank[]

  @@map("courses")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String   // e.g., "USER_CREATED", "CLASS_ASSIGNED"
  details   String   // e.g., "New student profile created for Kwame Asante"
  category  String   // e.g., "USER", "CLASS", "COURSE", "SYSTEM"
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model SystemSettings {
  id              Int      @id @default(1)
  academicYear    String   @default("2023/2024")
  semester        String   @default("First Semester")
  contactEmail    String   @default("admin@system.edu")
  // Grading scale: JSON array of {label, minPercent} sorted descending by minPercent.
  // e.g. [{"label":"A+","minPercent":90},{"label":"A","minPercent":85},...]
  // The last entry acts as the catch-all (lowest threshold). Anything below all
  // thresholds receives the label of the last entry (typically "F").
  gradingScale    Json     @default("[{\"label\":\"A+\",\"minPercent\":90},{\"label\":\"A\",\"minPercent\":85},{\"label\":\"A-\",\"minPercent\":80},{\"label\":\"B+\",\"minPercent\":75},{\"label\":\"B\",\"minPercent\":70},{\"label\":\"B-\",\"minPercent\":65},{\"label\":\"C+\",\"minPercent\":60},{\"label\":\"C\",\"minPercent\":55},{\"label\":\"C-\",\"minPercent\":50},{\"label\":\"D+\",\"minPercent\":45},{\"label\":\"D\",\"minPercent\":40},{\"label\":\"F\",\"minPercent\":0}]")
  updatedAt       DateTime @updatedAt

  @@map("system_settings")
}

model Assessment {
  id                Int              @id @default(autoincrement())
  title             String
  type              AssessmentType
  status            AssessmentStatus @default(DRAFT)
  courseId          Int
  course            Course           @relation(fields: [courseId], references: [id])
  lecturerId        Int
  lecturer          LecturerProfile  @relation(fields: [lecturerId], references: [id])
  totalMarks        Int
  startsAt          DateTime
  endsAt            DateTime
  durationMinutes   Int?
  maxAttempts       Int              @default(1)
  passwordProtected Boolean          @default(false)
  accessPassword    String?
  shuffleQuestions  Boolean          @default(false)
  shuffleOptions    Boolean          @default(false)
  isLocationBound   Boolean          @default(false)
  location          String?
  gradingStatus     GradingStatus    @default(NOT_GRADED)
  resultsReleased   Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  classes   AssessmentClass[]
  questions Question[]
  sections  AssessmentSection[]
  attempts  AssessmentAttempt[]

  @@map("assessments")
}

model AssessmentSection {
  id                     Int        @id @default(autoincrement())
  assessmentId           Int
  assessment             Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  name                   String
  type                   SectionType
  requiredQuestionsCount Int?

  questions    Question[]

  @@map("assessment_sections")
}

model AssessmentClass {
  id           Int        @id @default(autoincrement())
  assessmentId Int
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  classId      Int
  class        Class      @relation(fields: [classId], references: [id])

  @@unique([assessmentId, classId])
  @@map("assessment_classes")
}

model Question {
  id           Int         @id @default(autoincrement())
  assessmentId Int
  assessment   Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  sectionId    Int
  section      AssessmentSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  order        Int
  body         String
  marks        Int
  answerType   AnswerType?
  options      Json?
  correctOption Int?
  createdAt    DateTime    @default(now())

  rubricCriteria RubricCriterion[]
  studentAnswers StudentAnswer[]

  @@map("questions")
}

model RubricCriterion {
  id          Int      @id @default(autoincrement())
  questionId  Int
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  description String
  maxMarks    Int
  order       Int

  @@map("rubric_criteria")
}

model QuestionBank {
  id         Int             @id @default(autoincrement())
  lecturerId Int
  lecturer   LecturerProfile @relation(fields: [lecturerId], references: [id])
  courseId   Int?
  course     Course?         @relation(fields: [courseId], references: [id])
  title      String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  items QuestionBankItem[]

  @@map("question_banks")
}

model QuestionBankItem {
  id            Int          @id @default(autoincrement())
  bankId        Int
  bank          QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)
  type          SectionType
  body          String
  marks         Int
  answerType    AnswerType?
  options       Json?
  correctOption Int?
  createdAt     DateTime     @default(now())

  rubricCriteria QuestionBankItemRubric[]

  @@map("question_bank_items")
}

model QuestionBankItemRubric {
  id          Int              @id @default(autoincrement())
  itemId      Int
  item        QuestionBankItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  description String
  maxMarks    Int
  order       Int

  @@map("question_bank_item_rubrics")
}

model AssessmentAttempt {
  id             Int           @id @default(autoincrement())
  assessmentId   Int
  assessment     Assessment    @relation(fields: [assessmentId], references: [id])
  studentId      Int
  student        User          @relation(fields: [studentId], references: [id])
  startedAt      DateTime      @default(now())
  submittedAt    DateTime?
  status         AttemptStatus @default(IN_PROGRESS)
  score          Float?
  attemptNumber  Int
  questionOrder  Json          @default("[]")
  tabSwitchLog   Json          @default("[]")

  answers StudentAnswer[]

  @@unique([assessmentId, studentId, attemptNumber])
  @@map("assessment_attempts")
}

model StudentAnswer {
  id             Int               @id @default(autoincrement())
  attemptId      Int
  attempt        AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId     Int
  question       Question          @relation(fields: [questionId], references: [id])
  answerText     String?
  selectedOption Int?
  fileUrl        String?
  answerHash     String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([attemptId, questionId])
  @@map("student_answers")
}

// ---------------------------------------------------------------------------
// Grader feedback tables — owned and migrated by Prisma.
// The verion-ai-grader Django service reads and writes these tables but
// does NOT run migrations against them (managed = False in Django).
// ---------------------------------------------------------------------------

model GradingResult {
  id                Int             @id @default(autoincrement())
  attemptId         Int             @unique
  assessmentId      Int
  score             Float
  plagiarismFlagged Boolean         @default(false)
  gradedAt          DateTime
  errorNotes        String          @default("")

  answerFeedbacks   AnswerFeedback[]

  @@map("grader_gradingresult")
}

model AnswerFeedback {
  id               Int           @id @default(autoincrement())
  gradingResultId  Int
  gradingResult    GradingResult @relation(fields: [gradingResultId], references: [id])
  questionId       Int
  totalScore       Float
  maxScore         Float
  flag             String        @default("")
  flagReason       String        @default("")
  criteriaFeedback Json          @default("[]")
  bedrockError     Boolean       @default(false)

  @@map("grader_answerfeedback")
}