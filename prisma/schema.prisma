generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  LECTURER
  STUDENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  passwordHash String
  role         Role
  name         String?
  status       UserStatus @default(ACTIVE)
  dateJoined   DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  studentProfile  StudentProfile?
  lecturerProfile LecturerProfile?
  adminProfile    AdminProfile?

  @@map("users")
}

model StudentProfile {
  id      Int    @id
  user    User   @relation(fields: [id], references: [id])
  program String
  classId Int?
  class   Class? @relation(fields: [classId], references: [id])

  @@map("student_profiles")
}

model LecturerProfile {
  id         Int    @id
  user       User   @relation(fields: [id], references: [id])
  department String
  title      String
  courses    Course[] @relation("LecturerCourses")

  @@map("lecturer_profiles")
}

model AdminProfile {
  id   Int  @id
  user User @relation(fields: [id], references: [id])

  @@map("admin_profiles")
}

model Class {
  id          Int      @id @default(autoincrement())
  name        String   // e.g., "BIT Group B"
  level       Int      // e.g., 100
  isGraduated Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students StudentProfile[]
  courses  Course[]         @relation("ClassCourses")

  @@unique([name, level])
  @@map("classes")
}

model Course {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  title       String
  credits     Int      @default(3)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  classes   Class[]           @relation("ClassCourses")
  lecturers LecturerProfile[] @relation("LecturerCourses")

  @@map("courses")
}
